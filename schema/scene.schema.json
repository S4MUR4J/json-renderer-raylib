{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://scene-keeper.com/scene.schema.json",
	"title": "Scene",
	"description": "A scene described in SceneKeeper format",
	"type": "object",
	"properties": {
		"entities": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"id": { "type": "string" },
					"components": {
						"type": "object",
						"additionalProperties": { "type": "object" }
					}
				},
				"required": ["id", "components"]
			}
		}
	},
	"required" : ["entities"]
}
