{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 29,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Debug Build (Ninja)",
            "description": "SceneKeeper Renderer - debug configuration",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release Build (Ninja)",
            "description": "SceneKeeper Renderer - release configuration",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Build Debug",
            "configurePreset": "debug",
            "jobs": 8
        },
        {
            "name": "release",
            "displayName": "Build Release",
            "configurePreset": "release",
            "jobs": 8
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "displayName": "Run Tests (Debug)"
        },
        {
            "name": "release",
            "configurePreset": "release",
            "displayName": "Run Tests (Release)"
        }
    ],
    "packagePresets": [
        {
            "name": "release",
            "configurePreset": "release",
            "displayName": "Package Binary (Release)"
        }
    ],
    "workflowPresets": [
        {
            "name": "default",
            "steps": [
                {
                    "type": "configure",
                    "name": "debug"
                },
                {
                    "type": "build",
                    "name": "debug"
                }
            ]
        }
    ]
}